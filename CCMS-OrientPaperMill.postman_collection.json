    {
      "name": "3. Full Complaint Lifecycle (run top to bottom)",
      "item": [
        {
          "name": "Stage 1 \u2014 Create Complaint (Logged)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "pm.collectionVariables.set('complaintNo', data.complaint.complaintNo);",
                  "pm.test('Complaint created', () => pm.response.to.have.status(201));",
                  "console.log('complaintNo ->', data.complaint.complaintNo);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{base_url}}/api/complaints",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"invoiceNumber\": \"{{invoiceNumber}}\",\n  \"title\": \"Caustic Soda contamination \u2014 5 MT drum batch\",\n  \"remarks\": \"Customer reports visible discoloration and odor in 2 of 5 MT received.\",\n  \"reportedBy\": \"CUST-2000001\",\n  \"lineItemsInput\": [\n    {\n      \"invoiceItemNo\": \"10\",\n      \"sapMaterialNo\": \"MAT-2001\",\n      \"defectiveQty\": 2,\n      \"complaintTypeId\": \"CT06\"\n    }\n  ],\n  \"attachmentsInput\": [\n    { \"fileReference\": \"photo_drum_01.jpg\", \"fileType\": \"image\", \"description\": \"Discoloration close-up\" }\n  ]\n}"
            }
          }
        },
