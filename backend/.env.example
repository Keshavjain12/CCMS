# ============================================================
# CCMS — Orient Paper & Mill  |  Environment Configuration
# ============================================================

# Server
PORT=3000
NODE_ENV=development

# ─────────────────────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────────────────────
# Create the database once:  createdb -U postgres ccms
# Then load the schema:      psql -U postgres -d ccms -f db/schema.sql
#                            psql -U postgres -d ccms -f db/seed.sql
PGHOST=localhost
PGPORT=5432
PGDATABASE=ccms
PGUSER=postgres
PGPASSWORD=your_postgres_password
PG_POOL_MAX=10

# ─────────────────────────────────────────────────────────────
# SAP S/4HANA Integration
# ─────────────────────────────────────────────────────────────
# Set SAP_USE_MOCK=false when real SAP credentials are available.
# No other code changes are required — only these 5 lines.
SAP_USE_MOCK=true

SAP_BASE_URL=https://your-sap-host:port/sap/opu/odata/sap
SAP_USERNAME=your_service_account
SAP_PASSWORD=your_service_password

# Standard SAP OData service paths (confirm exact paths with SAP functional team)
SAP_BILLING_SERVICE=API_BILLING_DOCUMENT_SRV
SAP_BUSINESS_PARTNER_SERVICE=API_BUSINESS_PARTNER
SAP_PRODUCT_SERVICE=API_PRODUCT_SRV
SAP_CREDIT_MEMO_SERVICE=API_SALES_ORDER_SRV
SAP_PRICING_SERVICE=API_SLSPRICINGCONDITIONRECORD_SRV

# ─────────────────────────────────────────────────────────────
# Business Rules (configurable — do NOT hard-code in source)
# ─────────────────────────────────────────────────────────────
# Settlement above this amount triggers MD Approval (Section 8.1)
MD_APPROVAL_THRESHOLD=100000

# Settlement above this amount triggers mandatory Customer Visit (Section 7.2)
VISIT_THRESHOLD=50000

# Days before a Sample Awaited complaint is auto-escalated (Section 12.2)
SAMPLE_SLA_DAYS=7

# Days before any stage auto-escalates to supervisor (Section 12.2)
STAGE_SLA_DAYS=3

# Complaint window (days from invoice date) after which complaint is policy-flagged (Section 9)
DEFAULT_COMPLAINT_WINDOW_DAYS=30

# ── JWT Authentication (Section 12.3 — RBAC) ──────────────────────────────
JWT_SECRET=opm-ccms-change-this-in-production-use-a-long-random-string
JWT_EXPIRES=8h

# ── Notifications (Section 12.1 — Communication Matrix) ───────────────────
# NOTIFY_MODE=mock  → logs to console + /api/notifications (no real emails)
# NOTIFY_MODE=live  → sends real emails via SMTP
NOTIFY_MODE=mock
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
# For Gmail: use an App Password (myaccount.google.com → Security → App Passwords)
SMTP_PASS=your-app-password
SMTP_FROM=ccms-noreply@orientpaper.com

# ── SLA Engine (Section 12.2 — Auto-Escalation) ───────────────────────────
SLA_ENABLED=true
# How often the SLA engine checks complaints (minutes). Use 1 for demo.
SLA_TICK_MINUTES=60
# Days before a stage auto-escalates to supervisor
STAGE_SLA_DAYS=3
# Days before Sample_Awaited auto-escalates
SAMPLE_SLA_DAYS=7
# Days before Clarification_Sought auto-closes
CLARIFY_SLA_DAYS=30

# ── Security / Rate Limiting (Section 12.6) ───────────────────────────────
RATE_LIMIT_MAX=500
AUTH_RATE_LIMIT_MAX=20

# ── Data Retention & Archival (Section 12.7) ──────────────────────────────
ARCHIVE_ENABLED=true
ATTACHMENT_RETENTION_DAYS=365
COMPLAINT_ARCHIVE_DAYS=730
ARCHIVE_TICK_HOURS=24

# ── Phased Rollout (Section 12.8) ─────────────────────────────────────────
# 1 = Pilot (Paper / North India only)
# 2 = Extended (Paper all regions + Chemical North India)
# 3 = Full rollout (all business lines + regions)
ROLLOUT_PHASE=1
